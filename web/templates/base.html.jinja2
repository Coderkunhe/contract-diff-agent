<!DOCTYPE html>
<html lang="zh-CN" class="scroll-smooth">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}合同慧眼 — 合同智能比对{% endblock %}</title>
<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config = {
  theme: {
    extend: {
      fontFamily: {
        display: ['"PingFang SC"', '"Microsoft YaHei"', '"Noto Sans SC"', 'sans-serif'],
        body: ['"PingFang SC"', '"Microsoft YaHei"', '"Noto Sans SC"', 'sans-serif'],
        mono: ['"SF Mono"', '"JetBrains Mono"', '"Menlo"', 'monospace'],
      },
      colors: {
        brand: {
          50: '#f0f4ff', 100: '#dbe4ff', 200: '#bac8ff', 300: '#91a7ff',
          400: '#748ffc', 500: '#5c7cfa', 600: '#4c6ef5', 700: '#4263eb',
          800: '#3b5bdb', 900: '#364fc7',
        },
        accent: {
          50: '#fff9db', 100: '#fff3bf', 200: '#ffec99', 300: '#ffe066',
          400: '#ffd43b', 500: '#fcc419', 600: '#fab005',
        },
      },
    },
  },
}
</script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.x/dist/cdn.min.js"></script>
<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  @keyframes pulse-ring {
    0%, 100% { box-shadow: 0 0 0 0 rgba(76,110,245,0.4); }
    50% { box-shadow: 0 0 0 12px rgba(76,110,245,0); }
  }
  .animate-fade-in { animation: fadeInUp 0.5s ease-out both; }
  .animate-shimmer {
    background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }
  .animate-pulse-ring { animation: pulse-ring 2s ease-out infinite; }
  .stagger-1 { animation-delay: 0.05s; }
  .stagger-2 { animation-delay: 0.1s; }
  .stagger-3 { animation-delay: 0.15s; }
  .stagger-4 { animation-delay: 0.2s; }
  .stagger-5 { animation-delay: 0.25s; }
  .stagger-6 { animation-delay: 0.3s; }
  .stagger-7 { animation-delay: 0.35s; }
  .stagger-8 { animation-delay: 0.4s; }
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

  /* ═══════════════════════════════════════════════
     Dark theme — 演示模式 (data-theme="dark")
     ═══════════════════════════════════════════════ */
  [data-theme="dark"] body {
    background: #0c0e1a !important;
  }
  [data-theme="dark"] header {
    background: rgba(12, 14, 26, 0.97) !important;
    border-color: #1e1e36 !important;
  }
  [data-theme="dark"] footer {
    background: rgba(12, 14, 26, 0.9) !important;
    border-color: #1e293b !important;
  }
  /* Cards & surfaces */
  [data-theme="dark"] .bg-white,
  [data-theme="dark"] .bg-white\/95,
  [data-theme="dark"] .bg-white\/98,
  [data-theme="dark"] .bg-white\/80 {
    background-color: #161830 !important;
  }
  [data-theme="dark"] .bg-slate-50,
  [data-theme="dark"] .bg-slate-50\/80,
  [data-theme="dark"] .bg-slate-50\/90 {
    background-color: #1a1c36 !important;
  }
  [data-theme="dark"] .bg-slate-100 { background-color: #1f203a !important; }
  /* Text */
  [data-theme="dark"] .text-slate-900 { color: #f1f5f9 !important; }
  [data-theme="dark"] .text-slate-800 { color: #e2e8f0 !important; }
  [data-theme="dark"] .text-slate-700 { color: #cbd5e1 !important; }
  [data-theme="dark"] .text-slate-600 { color: #cbd5e1 !important; }
  [data-theme="dark"] .text-slate-500 { color: #94a3b8 !important; }
  [data-theme="dark"] .text-slate-400 { color: #94a3b8 !important; }
  [data-theme="dark"] .text-slate-300 { color: #64748b !important; }
  /* Borders */
  [data-theme="dark"] .border-slate-200,
  [data-theme="dark"] .border-slate-200\/60 {
    border-color: #334155 !important;
  }
  [data-theme="dark"] .border-slate-100 { border-color: #1e1e36 !important; }
  [data-theme="dark"] .border-slate-300 { border-color: #475569 !important; }
  [data-theme="dark"] .border-t-slate-100 { border-top-color: #1e1e36 !important; }
  [data-theme="dark"] .border-t-slate-200 { border-top-color: #334155 !important; }
  /* Dividers */
  [data-theme="dark"] .border-t { border-top-color: #334155 !important; }
  /* Risk stat cards — transparent overlay on dark */
  [data-theme="dark"] .bg-red-100 { background-color: rgba(185, 28, 28, 0.2) !important; }
  [data-theme="dark"] .bg-amber-100 { background-color: rgba(180, 83, 9, 0.2) !important; }
  [data-theme="dark"] .bg-emerald-100 { background-color: rgba(4, 120, 87, 0.2) !important; }
  [data-theme="dark"] .bg-red-50\/80,
  [data-theme="dark"] .bg-red-50 { background-color: rgba(185, 28, 28, 0.15) !important; }
  [data-theme="dark"] .bg-amber-50\/80,
  [data-theme="dark"] .bg-amber-50 { background-color: rgba(180, 83, 9, 0.15) !important; }
  [data-theme="dark"] .bg-emerald-50 { background-color: rgba(4, 120, 87, 0.15) !important; }
  [data-theme="dark"] .bg-blue-50 { background-color: rgba(29, 78, 216, 0.15) !important; }
  [data-theme="dark"] .bg-brand-50 { background-color: rgba(76, 110, 245, 0.15) !important; }
  [data-theme="dark"] .bg-purple-50 { background-color: rgba(124, 58, 237, 0.15) !important; }
  /* Risk text — brighter on dark */
  [data-theme="dark"] .text-red-700 { color: #f87171 !important; }
  [data-theme="dark"] .text-red-600 { color: #f87171 !important; }
  [data-theme="dark"] .text-amber-700 { color: #fbbf24 !important; }
  [data-theme="dark"] .text-amber-600 { color: #fbbf24 !important; }
  [data-theme="dark"] .text-emerald-700 { color: #4ade80 !important; }
  [data-theme="dark"] .text-emerald-600 { color: #4ade80 !important; }
  [data-theme="dark"] .text-blue-700 { color: #60a5fa !important; }
  [data-theme="dark"] .text-blue-600 { color: #60a5fa !important; }
  [data-theme="dark"] .text-purple-700 { color: #a78bfa !important; }
  [data-theme="dark"] .text-purple-500 { color: #a78bfa !important; }
  /* Inputs / textareas */
  [data-theme="dark"] textarea,
  [data-theme="dark"] input[type="text"],
  [data-theme="dark"] input:not([type]) {
    background-color: #0c0e1a !important;
    color: #e2e8f0 !important;
    border-color: #2a2c44 !important;
  }
  /* Risk category tags */
  [data-theme="dark"] .bg-slate-100.text-slate-500 {
    background-color: #334155 !important;
    color: #94a3b8 !important;
  }
  /* Hover states */
  [data-theme="dark"] .hover\:bg-brand-100:hover { background-color: rgba(76, 110, 245, 0.15) !important; }
  [data-theme="dark"] .hover\:bg-slate-50:hover { background-color: #334155 !important; }
  [data-theme="dark"] .hover\:bg-slate-100:hover { background-color: #475569 !important; }
  [data-theme="dark"] .hover\:bg-emerald-50:hover { background-color: rgba(4, 120, 87, 0.2) !important; }
  [data-theme="dark"] .hover\:bg-red-50:hover { background-color: rgba(185, 28, 28, 0.2) !important; }
  [data-theme="dark"] .hover\:bg-purple-50:hover { background-color: rgba(124, 58, 237, 0.2) !important; }
  /* Filter buttons inactive */
  [data-theme="dark"] .bg-slate-50.text-slate-500 {
    background-color: #334155 !important;
    color: #94a3b8 !important;
  }
  /* Shadows */
  [data-theme="dark"] .shadow-sm { box-shadow: 0 1px 2px rgba(0,0,0,0.3) !important; }
  [data-theme="dark"] .shadow-lg,
  [data-theme="dark"] .shadow-xl { box-shadow: 0 10px 15px rgba(0,0,0,0.4) !important; }
  /* Snippet bg */
  [data-theme="dark"] .bg-slate-50.rounded-lg { background-color: #0c0e1a !important; }
  /* Version badge */
  [data-theme="dark"] .bg-slate-100.rounded-full { background-color: #334155 !important; }
  /* Demo card — 一键快速体验 */
  [data-theme="dark"] .from-accent-50 { --tw-gradient-from: rgba(250, 204, 21, 0.1) var(--tw-gradient-from-position) !important; }
  [data-theme="dark"] .to-brand-50 { --tw-gradient-to: rgba(76, 110, 245, 0.1) var(--tw-gradient-to-position) !important; }
  /* Footer / subtle surfaces */
  [data-theme="dark"] .border-t-2.border-slate-200 { border-color: #1e1e36 !important; }
  [data-theme="dark"] .bg-white\/80 { background-color: rgba(22, 24, 48, 0.8) !important; }
  /* Submit button in dark */
  [data-theme="dark"] .bg-slate-900 { background-color: #4f46e5 !important; }
  [data-theme="dark"] .hover\:bg-slate-800:hover { background-color: #4338ca !important; }
</style>
</head>
<body class="bg-gradient-to-br from-slate-200 via-slate-100 to-slate-100 text-slate-800 font-body antialiased min-h-screen flex flex-col">
  <!-- Top bar -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b-2 border-slate-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14">
        <a href="/" class="flex items-center gap-2.5 group">
          <span class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center text-white text-sm font-bold shadow-sm shadow-brand-200 group-hover:shadow-md group-hover:shadow-brand-300 transition-shadow">慧</span>
          <span class="font-semibold text-slate-800 text-base tracking-tight">合同慧眼</span>
        </a>
        <div class="flex items-center gap-3">
          <button onclick="toggleTheme()" class="text-[11px] text-slate-400 hover:text-brand-600 font-medium transition-colors cursor-pointer" id="themeToggle" title="切换深色/浅色主题">🌙</button>
          <a href="/learnings" class="text-[11px] text-slate-400 hover:text-brand-600 font-medium transition-colors">进化记录</a>
          <span class="text-[11px] text-slate-400 font-medium bg-slate-100 px-2 py-0.5 rounded-full">v{{ version }}</span>
        </div>
      </div>
    </div>
  </header>

  <!-- Main -->
  <main class="flex-1">
    {% block content %}{% endblock %}
  </main>

  <!-- Footer -->
  <footer class="border-t-2 border-slate-200 bg-white/80">
    <div class="max-w-7xl mx-auto px-4 py-4 text-center">
      <p class="text-[11px] text-slate-400">供内部审核使用 · 不构成正式法律意见</p>
    </div>
  </footer>
  <script>
  function toggleTheme() {
    const html = document.documentElement;
    const btn = document.getElementById('themeToggle');
    if (html.dataset.theme === 'dark') {
      html.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
      if (btn) btn.textContent = '🌙';
    } else {
      html.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
      if (btn) btn.textContent = '☀️';
    }
  }
  (function() {
    const saved = localStorage.getItem('theme');
    const btn = document.getElementById('themeToggle');
    if (saved === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
      if (btn) btn.textContent = '☀️';
    }
  })();
  </script>
</body>
</html>
