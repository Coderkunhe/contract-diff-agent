{% extends "base.html.jinja2" %}
{% block title %}比对中 — 合同慧眼{% endblock %}
{% block content %}
<div class="max-w-5xl mx-auto px-4 py-8" x-data="streamer('{{ job.id }}')">
  <!-- Progress header -->
  <div class="bg-white rounded-2xl border border-slate-200 p-6 mb-6 sticky top-[72px] z-30 backdrop-blur-sm bg-white/95">
    <div class="flex items-center gap-4 mb-3">
      <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center"
           :class="status === 'done' ? 'bg-emerald-50 text-emerald-600' : 'bg-brand-50 text-brand-600'">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
             :class="status !== 'done' && 'animate-spin'">
          <template x-if="status === 'done'">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </template>
          <template x-if="status !== 'done'">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
          </template>
        </svg>
      </div>
      <div class="flex-1">
        <div class="flex items-center justify-between mb-1">
          <span class="text-sm font-semibold text-slate-700" x-text="stepLabel">准备中</span>
          <span class="text-xs font-mono text-slate-400" x-text="statText"></span>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-2 overflow-hidden">
          <div class="h-full rounded-full transition-all duration-700 ease-out"
               :class="status === 'done' ? 'bg-emerald-500' : 'bg-brand-600'"
               :style="'width: ' + Math.max(progress, 2) + '%'"></div>
        </div>
      </div>
    </div>
    <!-- Live stats -->
    <div class="flex gap-4 text-xs text-slate-400">
      <span>🕐 <span x-text="elapsed">0</span>s</span>
      <span>📝 <span x-text="changeCount">0</span> 条变化</span>
      <span x-show="highCount > 0">🔴 高风险 <span x-text="highCount" class="text-red-500 font-bold"></span></span>
    </div>
    <!-- Error -->
    <div x-show="errorMsg" class="mt-3 bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-700" x-text="errorMsg" style="display:none"></div>
  </div>

  <!-- Live change feed -->
  <div class="space-y-3" id="changeFeed">
    <template x-for="change in changes" :key="change.id">
      <div class="bg-white rounded-xl border border-slate-200 p-4 animate-fade-in hover:shadow-sm transition-shadow"
           :class="change.risk_level === 'high' ? 'border-l-[3px] border-l-red-400' : ''"
           x-transition:enter="transition ease-out duration-300"
           x-transition:enter-start="opacity-0 -translate-y-2"
           x-transition:enter-end="opacity-100 translate-y-0">
        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-6 h-6 rounded-lg flex items-center justify-center text-[10px] font-bold"
               :class="{
                 'bg-red-100 text-red-600': change.risk_level === 'high',
                 'bg-amber-100 text-amber-600': change.risk_level === 'medium',
                 'bg-emerald-100 text-emerald-600': change.risk_level === 'low'
               }"
               x-text="change.risk_level === 'high' ? '!' : change.risk_level === 'medium' ? '!' : 'i'"></div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-1.5 mb-1 flex-wrap">
              <span class="text-[10px] font-mono text-slate-400" x-text="change.id"></span>
              <span class="text-[10px] px-1.5 py-0.5 rounded font-medium"
                    :class="{
                      'bg-emerald-50 text-emerald-700': change.change_type === 'added',
                      'bg-red-50 text-red-700': change.change_type === 'removed',
                      'bg-blue-50 text-blue-700': change.change_type === 'modified'
                    }"
                    x-text="{'added':'新增','removed':'删除','modified':'修改'}[change.change_type] || change.change_type"></span>
              <span class="text-[10px] px-1.5 py-0.5 rounded font-medium"
                    :class="{
                      'bg-red-50 text-red-700': change.risk_level === 'high',
                      'bg-amber-50 text-amber-700': change.risk_level === 'medium',
                      'bg-emerald-50 text-emerald-700': change.risk_level === 'low'
                    }"
                    x-text="{'high':'高风险','medium':'中风险','low':'低风险'}[change.risk_level]"></span>
            </div>
            <p class="text-sm font-medium text-slate-800 mb-2" x-text="change.brief"></p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-2 mb-2" x-show="change.v1_snippet || change.v2_snippet">
              <div class="bg-slate-50 rounded-lg p-2 border border-slate-100" x-show="change.v1_snippet">
                <div class="text-[10px] text-slate-400 font-semibold mb-0.5">V1 原文</div>
                <div class="text-xs text-slate-600 whitespace-pre-wrap line-clamp-2" x-text="change.v1_snippet || ''"></div>
              </div>
              <div class="bg-slate-50 rounded-lg p-2 border border-slate-100" x-show="change.v2_snippet">
                <div class="text-[10px] text-slate-400 font-semibold mb-0.5">V2 原文</div>
                <div class="text-xs text-slate-600 whitespace-pre-wrap line-clamp-2" x-text="change.v2_snippet || ''"></div>
              </div>
            </div>
            <div x-show="change.risk_note" class="rounded-lg p-2 text-xs mb-1"
                 :class="{
                   'bg-red-50 text-red-700 border border-red-100': change.risk_level === 'high',
                   'bg-amber-50 text-amber-700 border border-amber-100': change.risk_level === 'medium',
                   'bg-slate-50 text-slate-600 border border-slate-100': change.risk_level === 'low'
                 }">
              <span class="font-semibold">⚠ 风险提示：</span> <span x-text="change.risk_note"></span>
            </div>
            <div class="flex items-center gap-2 text-[10px] text-slate-400 flex-wrap">
              <span x-show="change.clause_ref_v2" x-text="change.clause_ref_v2"></span>
              <template x-for="cat in change.risk_categories" :key="cat">
                <span class="bg-slate-100 text-slate-500 px-1.5 py-0.5 rounded">{{ cat }}</span>
              </template>
              <span x-show="change.attention_for" x-text="'👤 ' + change.attention_for"></span>
            </div>
          </div>
        </div>
      </div>
    </template>
  </div>

  <!-- Done state -->
  <div x-show="status === 'done'" class="text-center py-10 animate-fade-in">
    <a :href="'/results/' + jobId" class="inline-flex items-center gap-2 px-6 py-3 bg-slate-900 text-white rounded-2xl font-semibold hover:bg-slate-800 transition-colors shadow-lg shadow-slate-200">
      查看完整报告
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
      </svg>
    </a>
  </div>
</div>

<script>
function streamer(jobId) {
  return {
    jobId: jobId,
    status: 'connecting',
    progress: 0,
    stepLabel: '连接中...',
    changes: [],
    changeCount: 0,
    highCount: 0,
    elapsed: 0,
    errorMsg: '',
    _es: null,
    _timer: null,

    get statText() {
      if (this.status === 'done') return '✅ 完成';
      return Math.round(this.progress) + '%';
    },

    init() {
      this._timer = setInterval(() => { this.elapsed++; }, 1000);
      this.connect();
    },

    connect() {
      this._es = new EventSource('/job/' + jobId + '/stream');

      this._es.addEventListener('progress', (e) => {
        const d = JSON.parse(e.data);
        this.status = d.status || this.status;
        this.progress = d.progress || this.progress;
        this.stepLabel = d.step || d.message || this.stepLabel;
      });

      this._es.addEventListener('change', (e) => {
        const d = JSON.parse(e.data);
        this.changes = [d, ...this.changes];
        this.changeCount = this.changes.length;
        if (d.risk_level === 'high') this.highCount++;
      });

      this._es.addEventListener('summary', (e) => {
        const d = JSON.parse(e.data);
        this.changeCount = d.total_changes || this.changeCount;
      });

      this._es.addEventListener('done', (e) => {
        this.status = 'done';
        this.progress = 100;
        this.stepLabel = '比对完成';
        this._es.close();
        clearInterval(this._timer);
      });

      this._es.addEventListener('error', (e) => {
        try {
          const d = JSON.parse(e.data);
          this.errorMsg = d.error || '连接失败';
        } catch(_) {
          this.errorMsg = '连接中断，请刷新重试';
        }
        this._es.close();
        clearInterval(this._timer);
      });

      this._es.onerror = () => {
        if (this._es.readyState === EventSource.CLOSED) {
          clearInterval(this._timer);
        }
      };
    }
  }
}
</script>
{% endblock %}
