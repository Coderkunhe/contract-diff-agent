{% extends "base.html.jinja2" %}
{% block title %}比对结果 — 合同慧眼{% endblock %}
{% block content %}
{% set summary = data.diff_summary %}
{% set changes = data.changes %}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8" x-data="resultsPage()">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-8 gap-4 animate-fade-in">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">比对报告</h1>
      <p class="text-slate-500 text-sm mt-1.5">
        {{ job.v1_filename }} <span class="text-slate-300">vs</span> {{ job.v2_filename }}
      </p>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-[11px] text-slate-400 bg-slate-100 px-2.5 py-1 rounded-full font-medium">
        {{ summary.total_changes }} 处差异
      </span>
      <a href="/api/results/{{ job.id }}/json"
         class="text-[11px] text-brand-600 bg-brand-50 hover:bg-brand-100 px-2.5 py-1 rounded-full font-medium transition-colors">
        JSON ↓
      </a>
    </div>
  </div>

  <!-- Stat cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-2xl border border-slate-200 p-5 text-center animate-fade-in stagger-1">
      <div class="text-5xl font-bold text-slate-800 tracking-tight">{{ summary.total_changes }}</div>
      <div class="text-xs text-slate-400 mt-1.5 font-medium">总差异</div>
    </div>
    <div class="bg-red-50/60 rounded-2xl border border-red-200/60 p-5 text-center animate-fade-in stagger-2">
      <div class="text-4xl font-bold text-red-600 tracking-tight">{{ summary.high_risk }}</div>
      <div class="text-xs text-red-500 mt-1.5 font-medium">高风险</div>
    </div>
    <div class="bg-amber-50/60 rounded-2xl border border-amber-200/60 p-5 text-center animate-fade-in stagger-3">
      <div class="text-4xl font-bold text-amber-600 tracking-tight">{{ summary.medium_risk }}</div>
      <div class="text-xs text-amber-500 mt-1.5 font-medium">中风险</div>
    </div>
    <div class="bg-emerald-50/60 rounded-2xl border border-emerald-200/60 p-5 text-center animate-fade-in stagger-4">
      <div class="text-4xl font-bold text-emerald-600 tracking-tight">{{ summary.low_risk }}</div>
      <div class="text-xs text-emerald-500 mt-1.5 font-medium">低风险</div>
    </div>
  </div>

  <!-- Risk frequency -->
  <div class="bg-white rounded-2xl border border-slate-200 p-6 mb-8 animate-fade-in stagger-5">
    <h3 class="text-sm font-semibold text-slate-700 mb-4">风险类别分布</h3>
    <div class="space-y-3">
      {% for name, count in sorted_freq %}
      <div class="flex items-center gap-3">
        <span class="text-xs text-slate-600 w-24 truncate font-medium">{{ name }}</span>
        <div class="flex-1 bg-slate-100 rounded-full h-5 overflow-hidden relative">
          <div class="absolute inset-0 bg-gradient-to-r from-brand-500 to-brand-400 rounded-full transition-all duration-1000 ease-out"
               style="width: 0%"
               x-data x-init="setTimeout(() => $el.style.width = '{{ (count / max_freq_val * 100) | int }}%', 200)"></div>
        </div>
        <span class="text-xs tabular-nums text-slate-400 font-mono w-8 text-right">{{ count }}</span>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- Filter bar -->
  <div class="sticky top-[58px] z-40 bg-white/90 backdrop-blur-md rounded-2xl border border-slate-200 p-4 mb-6 flex flex-wrap items-center gap-3 animate-fade-in stagger-6">
    <span class="text-[11px] text-slate-400 font-semibold uppercase tracking-wider">风险</span>
    <button @click="riskFilter = 'all'" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-200"
            :class="riskFilter === 'all' ? 'bg-slate-800 text-white shadow-sm' : 'bg-slate-50 text-slate-500 hover:bg-slate-100'">全部</button>
    <button @click="riskFilter = 'high'" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-200"
            :class="riskFilter === 'high' ? 'bg-red-600 text-white shadow-sm' : 'bg-red-50 text-red-600 hover:bg-red-100'">高风险</button>
    <button @click="riskFilter = 'medium'" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-200"
            :class="riskFilter === 'medium' ? 'bg-amber-600 text-white shadow-sm' : 'bg-amber-50 text-amber-600 hover:bg-amber-100'">中风险</button>
    <button @click="riskFilter = 'low'" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-200"
            :class="riskFilter === 'low' ? 'bg-emerald-600 text-white shadow-sm' : 'bg-emerald-50 text-emerald-600 hover:bg-emerald-100'">低风险</button>

    <span class="w-px h-5 bg-slate-200 mx-1"></span>
    <span class="text-[11px] text-slate-400 font-semibold uppercase tracking-wider">类型</span>
    <button @click="typeFilter = 'all'" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-200"
            :class="typeFilter === 'all' ? 'bg-slate-800 text-white shadow-sm' : 'bg-slate-50 text-slate-500 hover:bg-slate-100'">全部</button>
    <button @click="typeFilter = 'modified'" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-200"
            :class="typeFilter === 'modified' ? 'bg-blue-600 text-white shadow-sm' : 'bg-blue-50 text-blue-600 hover:bg-blue-100'">修改</button>
    <button @click="typeFilter = 'added'" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-200"
            :class="typeFilter === 'added' ? 'bg-emerald-600 text-white shadow-sm' : 'bg-emerald-50 text-emerald-600 hover:bg-emerald-100'">新增</button>
    <button @click="typeFilter = 'removed'" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-200"
            :class="typeFilter === 'removed' ? 'bg-red-600 text-white shadow-sm' : 'bg-red-50 text-red-600 hover:bg-red-100'">删除</button>

    <div class="flex-1"></div>
    <span class="text-xs text-slate-400">显示 {{ changes | length }} 条</span>
  </div>

  <!-- Changes list -->
  <div class="space-y-3">
    {% for change in changes %}
    <div class="bg-white rounded-2xl border border-slate-200 p-6 transition-all duration-200 hover:shadow-md animate-fade-in stagger-{{ (loop.index % 8) + 1 if loop.index < 9 else 8 }}"
         x-show="match('{{ change.risk_level }}', '{{ change.change_type }}')"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 -translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         :class="'{{ change.risk_level }}' === 'high' ? 'border-l-[3px] border-l-red-400' : ''">
      <div class="flex items-start gap-4">
        <!-- Confirm toggle -->
        <div class="flex-shrink-0 pt-0.5 text-center" x-data="{ ok: false }">
          <button @click="ok = !ok; $dispatch('confirm', {id: '{{ change.id }}', value: ok})"
                  class="px-3 py-1.5 rounded-lg text-xs font-medium border-2 transition-all duration-200"
                  :class="ok ? 'bg-emerald-500 border-emerald-500 text-white' : 'border-slate-200 text-slate-400 hover:border-emerald-300 hover:text-emerald-500'">
            <span x-text="ok ? '✓ 已确认' : '确认'"></span>
          </button>
        </div>
        <!-- Risk badge -->
        <div class="flex-shrink-0 pt-0.5">
          <div class="w-8 h-8 rounded-xl flex items-center justify-center text-xs font-bold
                      {% if change.risk_level == 'high' %}bg-red-100 text-red-600
                      {% elif change.risk_level == 'medium' %}bg-amber-100 text-amber-600
                      {% else %}bg-emerald-100 text-emerald-600{% endif %}">
            {{ {'high': '!', 'medium': '!', 'low': 'i'}.get(change.risk_level, '?') }}
          </div>
        </div>

        <div class="flex-1 min-w-0">
          <!-- Top row -->
          <div class="flex items-center gap-2 mb-2 flex-wrap">
            <span class="text-[11px] font-mono text-slate-400">{{ change.id }}</span>
            {% if change.change_type == 'added' %}
            <span class="text-[11px] px-2 py-0.5 rounded-md bg-emerald-50 text-emerald-700 font-medium">+ 新增</span>
            {% elif change.change_type == 'removed' %}
            <span class="text-[11px] px-2 py-0.5 rounded-md bg-red-50 text-red-700 font-medium">− 删除</span>
            {% else %}
            <span class="text-[11px] px-2 py-0.5 rounded-md bg-blue-50 text-blue-700 font-medium">~ 修改</span>
            {% endif %}
            <span class="text-[11px] px-2 py-0.5 rounded-md font-medium
                         {% if change.risk_level == 'high' %}bg-red-50 text-red-700
                         {% elif change.risk_level == 'medium' %}bg-amber-50 text-amber-700
                         {% else %}bg-emerald-50 text-emerald-700{% endif %}">
              {{ {'high': '高风险', 'medium': '中风险', 'low': '低风险'}.get(change.risk_level, '') }}
            </span>
            {% if change.is_favorable == true %}
            <span class="text-[11px] text-emerald-600 font-medium">✓ 有利</span>
            {% elif change.is_favorable == false %}
            <span class="text-[11px] text-red-600 font-medium">✗ 不利</span>
            {% endif %}
            {% if change.clause_ref_v2 or change.clause_ref_v1 %}
            <span class="text-[10px] text-slate-400 font-mono ml-auto">{{ change.clause_ref_v2 or change.clause_ref_v1 }}</span>
            {% endif %}
          </div>

          <!-- Brief -->
          <p class="font-semibold text-slate-800 text-base mb-2">{{ change.brief }}</p>

          <!-- Side-by-side snippets -->
          {% if change.v1_snippet or change.v2_snippet %}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2 mb-2" x-data="{ expanded: false }">
            <div class="bg-slate-50 rounded-lg p-2.5 border border-slate-100">
              <div class="text-[10px] text-slate-400 font-semibold uppercase tracking-wider mb-1">{{ job.v1_filename }}</div>
              <div class="text-xs text-slate-600 leading-relaxed whitespace-pre-wrap" :class="expanded ? '' : 'line-clamp-2'">{{ change.v1_snippet or '（无对应条款）' }}</div>
            </div>
            <div class="bg-slate-50 rounded-lg p-2.5 border border-slate-100">
              <div class="text-[10px] text-slate-400 font-semibold uppercase tracking-wider mb-1">{{ job.v2_filename }}</div>
              <div class="text-xs text-slate-600 leading-relaxed whitespace-pre-wrap" :class="expanded ? '' : 'line-clamp-2'">{{ change.v2_snippet or '（无对应条款）' }}</div>
            </div>
            <button @click="expanded = !expanded" class="col-span-full text-center text-xs text-brand-600 hover:text-brand-700 font-medium transition-colors"
                    x-text="expanded ? '收起 ▲' : '展开全文 ▼'"></button>
          </div>
          {% endif %}

          <!-- Risk note -->
          {% if change.risk_note %}
          <div class="rounded-lg p-2.5 mb-2 text-sm leading-relaxed
                      {% if change.risk_level == 'high' %}bg-red-50/80 text-red-700 border border-red-200/60
                      {% elif change.risk_level == 'medium' %}bg-amber-50/80 text-amber-700 border border-amber-200/60
                      {% else %}bg-slate-50 text-slate-600 border border-slate-200/60{% endif %}">
            <span class="font-semibold">⚠ 风险提示：</span>{{ change.risk_note }}
          </div>
          {% endif %}

          <!-- Meta -->
          <div class="flex items-center gap-2 flex-wrap">
            {% for cat_name in change.risk_category_names %}
            <span class="text-[10px] bg-slate-100 text-slate-500 px-2 py-0.5 rounded-md font-medium">{{ cat_name }}</span>
            {% endfor %}
            {% if change.attention_for %}
            <span class="text-[10px] text-slate-400">👤 {{ change.attention_for }}</span>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>

  <!-- Empty state -->
  <div x-show="visibleCount === 0" class="text-center py-20 animate-fade-in" style="display:none">
    <div class="text-4xl mb-3">🔍</div>
    <p class="text-slate-600 font-medium">没有匹配的变更</p>
    <p class="text-slate-400 text-sm mt-1">尝试调整筛选条件</p>
  </div>

  <!-- Confirmation bar -->
  <div class="fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-md border-t border-slate-200 px-6 py-4 z-50"
       x-show="totalChanges > 0" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="translate-y-full" x-transition:enter-end="translate-y-0">
    <div class="max-w-7xl mx-auto flex items-center gap-4">
      <div class="flex-1 flex items-center gap-3">
        <div class="text-sm font-medium text-slate-600">
          已确认 <span class="font-bold text-slate-800" x-text="confirmedCount">0</span> / <span x-text="totalChanges">{{ changes | length }}</span>
        </div>
        <div class="flex-1 max-w-xs bg-slate-100 rounded-full h-2 overflow-hidden">
          <div class="h-full bg-emerald-500 rounded-full transition-all duration-500"
               :style="'width: ' + confirmPct + '%'"></div>
        </div>
      </div>
      <button @click="downloadReport()"
              :disabled="confirmedCount === 0"
              class="px-5 py-2 rounded-xl text-sm font-semibold transition-all duration-200"
              :class="confirmedCount === totalChanges ? 'bg-slate-900 text-white hover:bg-slate-800 shadow-lg' : 'bg-slate-100 text-slate-400 cursor-not-allowed'"
              x-text="confirmedCount === totalChanges ? '⬇ 下载确认报告' : '⬇ 下载报告 (' + confirmedCount + '条)'"></button>
    </div>
  </div>
</div>

<script>
function resultsPage() {
  return {
    riskFilter: 'all',
    typeFilter: 'all',
    confirmed: {{ confirmed_ids | tojson }},
    get totalChanges() { return {{ changes | length }}; },
    get confirmedCount() { return this.confirmed.length; },
    get confirmPct() { return this.totalChanges ? Math.round(this.confirmedCount / this.totalChanges * 100) : 0; },

    init() {
      const jobId = window.location.pathname.split('/').pop();
      const saved = localStorage.getItem('confirmed_' + jobId);
      if (saved) {
        try { this.confirmed = JSON.parse(saved); } catch(e) {}
      }

      // Listen for confirm events from individual cards
      window.addEventListener('confirm', (e) => {
        const { id, value } = e.detail;
        if (value) {
          if (!this.confirmed.includes(id)) this.confirmed.push(id);
        } else {
          this.confirmed = this.confirmed.filter(x => x !== id);
        }
        localStorage.setItem('confirmed_' + jobId, JSON.stringify(this.confirmed));
      });
    },

    match(risk, type) {
      if (this.riskFilter !== 'all' && risk !== this.riskFilter) return false;
      if (this.typeFilter !== 'all' && type !== this.typeFilter) return false;
      return true;
    },

    downloadReport() {
      if (!this.confirmed.length) return;
      const ids = this.confirmed;
      fetch('/api/results/' + window.location.pathname.split('/').pop() + '/json')
        .then(r => r.json())
        .then(data => {
          const filtered = {
            ...data,
            changes: data.changes.filter(c => ids.includes(c.id)),
            confirmation: {
              confirmed_count: ids.length,
              total: data.changes.length,
              confirmed_at: new Date().toISOString(),
            }
          };
          const blob = new Blob([JSON.stringify(filtered, null, 2)], {type: 'application/json'});
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = 'contract-diff-confirmed.json';
          a.click();
        });
    },
  }
}
</script>
{% endblock %}
