{% extends "base.html.jinja2" %}
{% block title %}上传合同 — 合同慧眼{% endblock %}
{% block content %}
<div class="max-w-3xl mx-auto px-4 py-12 sm:py-20" x-data="uploader()"
     @dragover.prevent="dragover = true"
     @dragleave="dragover = false"
     @drop.prevent="dragover = false">

  <!-- Drag overlay -->
  <div x-show="dragover" x-transition.opacity
       class="fixed inset-0 z-50 bg-brand-50/70 backdrop-blur-sm flex items-center justify-center pointer-events-none">
    <div class="text-center">
      <div class="w-24 h-24 rounded-3xl bg-brand-100 text-brand-600 flex items-center justify-center mx-auto mb-4 animate-bounce">
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
        </svg>
      </div>
      <p class="text-xl font-bold text-brand-700">释放文件以上传</p>
      <p class="text-sm text-brand-500 mt-1">支持 PDF / DOCX 格式</p>
    </div>
  </div>

  <!-- Hero -->
  <div class="text-center mb-10 animate-fade-in">
    <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight mb-3">
      合同版本智能比对
    </h1>
    <p class="text-slate-500 text-base sm:text-lg max-w-lg mx-auto leading-relaxed">
      上传两份合同 PDF，AI 自动识别差异并生成通俗风险提示
    </p>
  </div>

  <!-- Upload form -->
  <form action="/upload" method="post" enctype="multipart/form-data"
        class="space-y-5" x-ref="form">

    <!-- V1 card -->
    <div class="animate-fade-in stagger-1">
      <div class="relative bg-white rounded-2xl border-2 transition-all duration-300 overflow-hidden group"
           :class="v1Name ? 'border-brand-400 shadow-sm shadow-brand-50' : (dragover ? 'border-brand-300 bg-brand-50/20 border-dashed' : 'border-slate-200 hover:border-brand-300')"
           x-on:dragover.prevent="$el.classList.add('border-brand-500','bg-brand-50/40','scale-[1.01]')"
           x-on:dragleave.prevent="$el.classList.remove('border-brand-500','bg-brand-50/40','scale-[1.01]')"
           x-on:drop.prevent="handleDrop($event, 'v1'); $el.classList.remove('border-brand-500','bg-brand-50/40','scale-[1.01]')">
        <label class="cursor-pointer block p-8 sm:p-10">
          <input type="file" name="v1_file" accept=".pdf,.docx" required
                 @change="handleFile($event, 'v1')" class="hidden" x-ref="v1Input">
          <div class="flex items-center gap-5">
            <div class="flex-shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center transition-all duration-300"
                 :class="v1Name ? 'bg-brand-50 text-brand-600' : 'bg-slate-100 text-slate-400 group-hover:bg-brand-50 group-hover:text-brand-500'">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-semibold uppercase tracking-wider text-slate-400 bg-slate-100 px-2 py-0.5 rounded-md">旧版本</span>
                <span class="text-xs text-slate-400">V1</span>
              </div>
              <p class="font-semibold text-slate-700 text-lg" x-text="v1DisplayText">点击选择或拖拽文件</p>
              <p class="text-sm text-slate-400 mt-0.5" x-show="!v1Name">支持 .pdf / .docx 格式</p>
              <p class="text-sm text-brand-600 mt-0.5" x-show="v1Size" x-text="'大小: ' + v1Size"></p>
            </div>
            <div x-show="v1Name" class="flex-shrink-0">
              <button type="button" @click="clearFile('v1')"
                      class="w-8 h-8 rounded-lg bg-slate-100 hover:bg-red-50 text-slate-400 hover:text-red-500 flex items-center justify-center transition-colors"
                      title="移除文件">&times;</button>
            </div>
          </div>
        </label>
      </div>
    </div>

    <!-- Swap arrow -->
    <div class="flex justify-center animate-fade-in stagger-2">
      <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center">
        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
    </div>

    <!-- V2 card -->
    <div class="animate-fade-in stagger-3">
      <div class="relative bg-white rounded-2xl border-2 transition-all duration-300 overflow-hidden"
           :class="v2Name ? 'border-brand-400 shadow-sm shadow-brand-50' : (dragover ? 'border-brand-300 bg-brand-50/20 border-dashed' : 'border-slate-200 hover:border-brand-300')"
           x-on:dragover.prevent="$el.classList.add('border-brand-500','bg-brand-50/40','scale-[1.01]')"
           x-on:dragleave.prevent="$el.classList.remove('border-brand-500','bg-brand-50/40','scale-[1.01]')"
           x-on:drop.prevent="handleDrop($event, 'v2'); $el.classList.remove('border-brand-500','bg-brand-50/40','scale-[1.01]')">
        <label class="cursor-pointer block p-8 sm:p-10">
          <input type="file" name="v2_file" accept=".pdf,.docx" required
                 @change="handleFile($event, 'v2')" class="hidden" x-ref="v2Input">
          <div class="flex items-center gap-5">
            <div class="flex-shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center transition-all duration-300"
                 :class="v2Name ? 'bg-brand-50 text-brand-600' : 'bg-slate-100 text-slate-400 group-hover:bg-brand-50 group-hover:text-brand-500'">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-semibold uppercase tracking-wider text-brand-600 bg-brand-50 px-2 py-0.5 rounded-md">新版本</span>
                <span class="text-xs text-slate-400">V2</span>
              </div>
              <p class="font-semibold text-slate-700 text-lg" x-text="v2DisplayText">点击选择或拖拽文件</p>
              <p class="text-sm text-slate-400 mt-0.5" x-show="!v2Name">支持 .pdf / .docx 格式</p>
              <p class="text-sm text-brand-600 mt-0.5" x-show="v2Size" x-text="'大小: ' + v2Size"></p>
            </div>
            <div x-show="v2Name" class="flex-shrink-0">
              <button type="button" @click="clearFile('v2')"
                      class="w-8 h-8 rounded-lg bg-slate-100 hover:bg-red-50 text-slate-400 hover:text-red-500 flex items-center justify-center transition-colors"
                      title="移除文件">&times;</button>
            </div>
          </div>
        </label>
      </div>
    </div>

    <!-- One-click demo -->
    <div class="animate-fade-in stagger-4 pb-1">
      <a href="/demo"
         class="flex items-center gap-4 bg-gradient-to-r from-accent-50 to-brand-50 rounded-2xl border border-brand-200/50 p-5 hover:border-brand-300 hover:shadow-md hover:shadow-brand-50 transition-all group">
        <div class="flex-shrink-0 w-11 h-11 rounded-xl bg-brand-600 text-white flex items-center justify-center group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <div class="flex-1">
          <div class="font-semibold text-slate-800 text-sm">一键快速体验</div>
          <div class="text-xs text-slate-500 mt-0.5">用内置天猫服务协议样本立刻体验合同比对全流程</div>
        </div>
        <svg class="w-5 h-5 text-brand-400 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Thorough mode toggle -->
    <div class="animate-fade-in stagger-5">
      <label class="flex items-center gap-3 bg-white rounded-2xl border border-slate-200 p-5 cursor-pointer hover:border-brand-300 transition-all">
        <input type="checkbox" name="thorough" value="1" class="w-5 h-5 rounded accent-brand-600">
        <div>
          <div class="font-semibold text-slate-700 text-sm">严谨模式</div>
          <div class="text-xs text-slate-400 mt-0.5">独立交叉验证 + LLM 反幻觉校验，准确率更高，耗时约 2 倍</div>
        </div>
      </label>
    </div>

    <!-- Submit -->
    <div class="pt-2 animate-fade-in stagger-6">
      <button type="submit"
              :disabled="!v1Name || !v2Name"
              class="w-full py-4 rounded-2xl font-semibold text-lg transition-all duration-300 flex items-center justify-center gap-2"
              :class="v1Name && v2Name
                ? 'bg-slate-900 text-white hover:bg-slate-800 shadow-lg shadow-slate-200 hover:shadow-xl hover:shadow-slate-300 hover:-translate-y-0.5'
                : 'bg-slate-100 text-slate-400 cursor-not-allowed'">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
        开始智能比对
      </button>
      <p class="text-center text-xs text-slate-400 mt-3">
        预计耗时 2–5 分钟 · AI 深度分析中请耐心等待
      </p>
    </div>
  </form>
</div>

<script>
function uploader() {
  return {
    dragover: false,
    v1Name: '',
    v2Name: '',
    v1Size: '',
    v2Size: '',
    get v1DisplayText() {
      if (!this.v1Name) return this.dragover ? '释放文件到此处' : '点击选择或拖拽文件';
      return this.v1Name;
    },
    get v2DisplayText() {
      if (!this.v2Name) return this.dragover ? '释放文件到此处' : '点击选择或拖拽文件';
      return this.v2Name;
    },

    _formatSize(bytes) {
      if (!bytes) return '';
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / 1048576).toFixed(1) + ' MB';
    },

    _setFile(file, side) {
      if (side === 'v1') {
        this.v1Name = file.name;
        this.v1Size = this._formatSize(file.size);
      } else {
        this.v2Name = file.name;
        this.v2Size = this._formatSize(file.size);
      }
    },

    handleFile(event, side) {
      const f = event.target.files[0];
      if (f) this._setFile(f, side);
    },

    handleDrop(event, side) {
      const f = event.dataTransfer.files[0];
      if (!f) return;
      const ext = f.name.toLowerCase().split('.').pop();
      if (!['pdf', 'docx'].includes(ext)) {
        alert('仅支持 PDF 和 DOCX 文件格式');
        return;
      }
      this._setFile(f, side);
      // Assign file to hidden input
      const refKey = side === 'v1' ? 'v1Input' : 'v2Input';
      const input = this.$refs[refKey];
      if (input) {
        const dt = new DataTransfer();
        dt.items.add(f);
        input.files = dt.files;
      }
    },

    clearFile(side) {
      if (side === 'v1') {
        this.v1Name = '';
        this.v1Size = '';
        if (this.$refs.v1Input) this.$refs.v1Input.value = '';
      } else {
        this.v2Name = '';
        this.v2Size = '';
        if (this.$refs.v2Input) this.$refs.v2Input.value = '';
      }
    }
  }
}
</script>
{% endblock %}
