# ── 单一 API 配置（必填，配一套就能跑）────────────────
# 模型选择决定 Provider（deepseek-* → DeepSeek直连，其余 → GMI代理）
# ⚠️ 单模型提醒：本项目设计为多模型池架构。
#    仅配置单一模型意味着模型不可用时系统无法自动降级切换。
#    后续功能升级（如多模态合同分析、多角度校验）可能依赖不同模型的互补能力，
#    建议至少保留一个备用模型以确保高可用。
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat

# ── Base URL（可选，通常无需设置）─────────────────────
# DeepSeek 模型自动使用 https://api.deepseek.com/v1
# 其他模型自动使用 https://api.gmi-serving.com/v1
# 也可手动覆盖：
# LLM_BASE_URL=https://your-custom-proxy.com/v1

# ── 多 Provider 高级设置（可选）────────────────────────
# 如需同时使用 DeepSeek + GMI 做模型池降级，
# 可为不同 provider 设置独立的 key：
# DEEPSEEK_API_KEY=sk-deepseek-key
# ANTHROPIC_API_KEY=your-gmi-jwt-key    # GMI proxy key

# ── 可调参数（均设有默认值，按需覆盖）─────────────────
# LLM_MAX_TOKENS=3000
# LLM_TIMEOUT=300
# LLM_BATCH_SIZE=25
# CLASSIFY_MAX_TOKENS=2500
# ENHANCE_MAX_TOKENS=2000
# VALIDATE_MAX_TOKENS=500
# MAX_RETRIES=3
# CHAPTER_RETRY_LIMIT=5
# MODEL_COOLDOWN_BASE=30
# MODEL_COOLDOWN_MAX=300
# CONFIDENCE_THRESHOLD=0.6
# ENHANCE_WORKERS=5
# VALIDATE_WORKERS=8
# MAX_JOBS=20
# WEB_WORKERS=2
# DATA_DIR=data
